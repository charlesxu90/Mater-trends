# Citation-source credentials for `mat-trend citations`.
# Copy to `.env` (gitignored) and fill in, or simply `export` these in your shell.
# Crossref needs no key; a contact email just joins its "polite pool".

# Contact email shared with Crossref + OpenAlex polite pools (optional).
OPENALEX_MAILTO=you@example.org

# Semantic Scholar API key — https://www.semanticscholar.org/product/api
# Enables the S2 source (batch lookups, ~1 request/second).
S2_API_KEY=

# OpenAlex API key — https://openalex.org (optional).
# Used for the free single-work endpoint; the metered bulk endpoint needs a funded key.
OPENALEX_API_KEY=
